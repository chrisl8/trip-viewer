{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tripviewer",
  "version": "0.1.3",
  "identifier": "com.tripviewer.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Trip Viewer",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**/*"]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.comodoca.com"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJBNTQxMjYwRTY5NUM1OTQKUldTVXhaWG1ZQkpVdWtSSFBxWnNzSnJYeE5sQlpBdnFqNkFqRFVOTG5DRlUwVzd0elE0RXJLVUEK",
      "endpoints": [
        "https://github.com/chrisl8/trip-viewer/releases/latest/download/latest.json"
      ]
    }
  }
}
